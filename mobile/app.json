{
  "expo": {
    "name": "PirateTracker",
    "slug": "piratetracker",
    "scheme": "piratetracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#06101b",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.piratetracker.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "PirateTracker uses your photo library so you can set an avatar and attach card photos to listings and messages."
        }
      ]
    ]
  }
}
